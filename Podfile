  use_frameworks!

  # Core TensorFlow Lite (includes FlexDelegate via the separate pod)
  pod 'TensorFlowLiteSwift', '~> 2.13.0'
  pod 'TensorFlowLiteSelectTfOps', '~> 2.13.0'
  
  # MLKit for face detection (required for FaceDetectorManager)
  pod 'GoogleMLKit/FaceDetection', '~> 4.0.0'
end
